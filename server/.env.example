# 复制为 .env 后修改
YT_DEBUG=false
YT_DB_URL=sqlite:///./yt.db

# 必须改！用 python -c 'import secrets;print(secrets.token_urlsafe(48))' 生成
YT_JWT_SECRET=please-replace-me-with-random-secret

# 必须改！用 python -c 'from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())' 生成
YT_MASTER_KEY=please-replace-me-with-fernet-key

# Token TTL
YT_ACCESS_TOKEN_TTL_MINUTES=60
YT_REFRESH_TOKEN_TTL_DAYS=30

# CORS（开发期允许全部；生产改成实际域名）
YT_CORS_ORIGINS=["*"]
